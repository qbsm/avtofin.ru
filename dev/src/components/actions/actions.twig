<section class="actions section">
    <div class="container">
        <div class="section__item heading-wrap">
            <span class="heading text-center">{{ data.heading | raw }}</span>
            <div class="divider"></div>
        </div>
        <div class="section__item cards-wrap">
            {% for item in data.items %}
            <div class="card" style="background-image: url({{item.bg}});">
                <span class="card__title font-2-medium" >{{ item.title | raw }}</span>
                {% if item.subtitle %}
                <span class="card__subtitle font-2-regular" >{{ item.subtitle | raw }}</span>
                {% endif %}
                <button class="button button-3 button-md button-rounded">{{ item.button | raw }}</button>
                <div class="card__icon-wrap">
                    <img src="{{ item.icon}}" class="img-responsive">
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>