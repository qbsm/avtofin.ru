<form
  class="form js-form {{mod}} {% if city %}form-city{% endif %}"
  name="{{name}}"
  id="{{id}}"
>
    <div class="form__container">
            <div class="form__item input-wrap input-name">
                <label class="form__label" for="name">Ваше имя</label>
                <input type="text" id="name" class="form__input  js-form-name" placeholder="Введите имя" name="Имя" required>
                <span class="hidden js-form-name-error">Укажите имя. Допустимы только русские и английские буквы и пробел</span>
            </div>
            <div class="form__item input-wrap input-phone js-field-container">
                <label class="form__label" for="phone">Ваш телефон<span class="form__asterisk">*</span></label>
                <input
                type="tel"
                class="form__input js-form-phone"
                id="phone"
                placeholder="+7 (___) ___-__-__"
                name="Телефон"
                pattern="\+7 \(\d{3}\) \d{3}-\d{2}-\d{2}"
                required
                >
                <span class="hidden js-form-phone-error">Укажите телефон</span>
            </div>
        
            {% if city %}
            <input type="hidden" name="city" value="{{ city }}">
            {% else %}
            <div class="form__item select-wrap">
                <select id="select" class="form__select js-form-city" name="city" required>
                    <option value="Не выбрано">Выберите филиал</option>
                    {% for city in cities %}
                    <option value="{{ city }}">{{ city }}</option>
                    {% endfor %}
                </select>
            </div>
            {% endif %}
            <div class="form__item textarea-wrap">
                <label class="form__label" for="message">Краткое описание вопроса</label>
                <textarea type="text" id="message" class="form__textarea" placeholder="Введите текст" name="Текстареа"></textarea>
            </div>

            <div class="honeypot" aria-hidden="true" style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden">
                <label>Сайт<input type="text" name="website" value="" tabindex="-1" autocomplete="off"></label>
            </div>
            <input type="hidden" class="js-form-token" name="form_token" value="" data-token="{{ formToken }}">

            <div class="form__item spinner-wrap">
                <button type="submit" name="submit" class="form__submit button button-rounded {{ button.class }} js-send CKFormTrigger">
                    <span class="form__submit-title">{{button.text}}</span>
                    <span class="form__submit-loader spinner">
                        <span class="bounce1"></span>
                        <span class="bounce2"></span>
                        <span class="bounce3"></span>
                    </span>
                    <span class="form__submit-success">
                        <i class="fa fa-thumbs-o-up form__submit-icon" aria-hidden="true"></i>
                        Успешно отправлена
                    </span>
                </button>
            </div>

            <div class="form__item agree-wrap">
                <span class="form__agree">
                    Нажав на кнопку "Отправить заявку", я даю согласие на обработку моих персональных данных и получение рекламных предложений. С <a class="link link-1"
                        href="{{root_path}}/data/content/agree.pdf" target="_blank" class="">условиями</a> обработки персональных данных и получения предложений - ознакомлен и согласен.
                </span>
            </div>
        <div class="form__item hidden-wrap">
            <input type="hidden" name="subject" value="Оставлена заявка">
        </div>
    </div>
</form>
