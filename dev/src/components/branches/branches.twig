<section class="branches section">
    <div class="container">
        <div class="section__item heading-wrap">
            <span class="heading text-center">{{ data.heading | raw }}</span>
            <div class="divider"></div>
        </div>
        {% set mapCenter = currentBranch.location|default(data.center) %}
        {% set mapCenterSM = currentBranch.location|default(data.centerSM) %}
        {% set mapZoom = currentBranch ? 15 : data.zoom %}
        {% set mapZoomSM = currentBranch ? 14 : data.zoomSM %}
        <div class="section__item map-branches-wrap">
            <div class="section__subitem map-placemarks-wrap js-map" data-center="{{ mapCenter }}" data-centerSM="{{ mapCenterSM }}" data-zoom="{{ mapZoom }}" data-zoomSM="{{ mapZoomSM }}" data-container-id="map">
                <div class="section__inner placemarks-wrap">
                    <div class="placemark hidden">
                        {% for item in branches %}
                          <div class="map__balloon" data-location="{{item.location}}" data-image-size="64,90" data-image-offset="-32,-90" data-icon="assets/img/brand/placemark.png?v=3">
                            <a href="{{item.yandex}}" class="map__balloon__link" target="blank" rel="noopener noreferrer">
                              <img src="{{root}}data/img/map/yandex.svg" class="img-responsive">
                            </a>
                          </div>
                        {% endfor %}
                    </div>
                </div>
                <div class="section__inner map-wrap" id="map">
                </div>
            </div>
            <div class="section__subitem branches-wrap">
                <div class="card">
                    <div class="card__item working-wrap">
                        <span class="card__label">Единое время работы филиалов</span>
                        <span class="card__value"><span class="font-1-semibold">Пн-Пт</span> 09:00-20:00<br><span class="font-1-semibold">Сб-Вс</span> 09:00-19:00</span>
                    </div>
                </div>
                {% for item in branches %}
                <div class="card">
                    <div class="card__item city-wrap">
                        <span class="card__title font-2-medium">{{ item.city | raw }}
                    </div>
                    <div class="card__item link-wrap">
                        <a href="#" class="link link-a-b nowrap font-2-semibold card__map-link js-map-link" data-location="{{ item.location }}">Смотреть на карте <span class="mdi mdi-chevron-right"></span></a>
                    </div>
                    <div class="card__item address-wrap">
                        <span class="card__label">Адрес</span>
                        <span class="card__value">{{ item.address | raw }}</span>
                    </div>
                    <div class="card__item link-wrap">
                        <a href="tel:{{ item.phone.href }}" class="link link-a-b nowrap font-2-semibold card__phone">{{ item.phone.title | raw}}</a>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>
