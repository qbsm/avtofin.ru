<section class="nav section">
    <div class="container">
        {% for item in data.items %}
        <div class="nav__item link-wrap">
            <a data-href="{{ item.href }}" class="link link-a-b nav__link font-2-semibold uppercase {{ item.class }}">{{ item.title | raw }}</a>
        </div>
        {% endfor %}
    </div>
</section>