<section class="accordion section">
    <div class="container">
        <div class="section__item heading-wrap">
            <span class="heading text-center">{{ data.heading | raw }}</span>
            <div class="divider"></div>
        </div>
        <div class="section__item accordion-wrap">
            <div class="accordion">
                {% for accordion in data.items %}
                <div class="accordion__item js-accordion-item">
                    <div class="accordion__subitem title-wrap">
                        <span class="accordion__title">{{ accordion.title | raw }}</span>
                        <span class="mdi mdi-arrow-right accordion__arrow"></span>
                    </div>
                    <div class="accordion__subitem desc-wrap">
                        {% if accordion.desc %}
                        <span class="accordion__desc">{{ accordion.desc | raw }}</span>
                        {% endif %}
                        {% if accordion.image %}
                        <img src="{{ accordion.image }}" class="img-responsive">
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>