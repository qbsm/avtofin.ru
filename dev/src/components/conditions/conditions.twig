<section class="conditions section">
    <div class="container">
        <div class="section__item heading-wrap">
            <span class="heading text-center">{{ data.heading | raw }}</span>
            <span class="subheading text-center">{{ data.subheading | raw }}</span>
            <div class="divider"></div>
        </div>
        <div class="section__item list-wrap">
            <ul>
                {% for item in data.items %}
                <li>{{ item | raw }}</li>
                {% endfor %}
            </ul>
            <span class="desc">{{ data.example | raw }}</span>
            <span class="giver">{{ data.giver | raw }}</span>
        </div>
    </div>
</section>