{
  "name": "autosaim",
  "version": "1.0.0",
  "scripts": {
    "init": "npm install && composer install && npm run build",
    "start": "npm-run-all --parallel watch watch:js",
    "build:js": "NODE_ENV='production' webpack --config webpack.config.js",
    "watch:js": "webpack --watch",
    "watch": "gulp watch",
    "build": "gulp build --production && npm run build:js",
    "template": "gulp copy-template-js"
  },
  "dependencies": {
    "@59naga/babel-plugin-transform-array-from": "0.0.0",
    "es6-promise": "^4.2.4",
    "formatter.js": "^0.1.5",
    "jquery": "^3.2.1",
    "magnific-popup": "^1.1.0",
    "postcss-color-function": "^4.1.0"
  },
  "devDependencies": {
    "ismart-gulpfile": "^2.0.0",
    "ismart-webpack": "^1.0.0",
    "npm-run-all": "^4.1.5",
    "webpack": "^3.10.0",
    "yargs": "^8.0.2"
  },
  "overrides": {
    "sharp": "^0.33.5",
    "pngquant-bin": "^9.0.0"
  }
}
